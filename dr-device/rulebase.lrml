                        </ruleml:Atom>
                        <ruleml:Atom>
                            <ruleml:Rel iri="lc:high_gain"/>
                            <ruleml:Var type="lc:defendant">Defendant</ruleml:Var>
                            <ruleml:Data xsi:type="xs:string">true</ruleml:Data>
                        </ruleml:Atom>
                    </ruleml:And>
                </ruleml:if>
                <ruleml:then>
                    <ruleml:Atom>
                        <ruleml:Rel>art420_qualified</ruleml:Rel>
                        <ruleml:Var type=":defendant">Defendant</ruleml:Var>
                    </ruleml:Atom>
                </ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <!-- ps5_neg: qualified embezzlement defeats basic -->
        <lrml:PrescriptiveStatement key="ps5_neg">
            <ruleml:Rule key=":rule5_neg" closure="universal" strength="defeasible">
                <ruleml:if>
                    <ruleml:And>
                        <ruleml:Atom>
                            <ruleml:Rel>art420_qualified</ruleml:Rel>
                            <ruleml:Var type=":defendant">Defendant</ruleml:Var>
