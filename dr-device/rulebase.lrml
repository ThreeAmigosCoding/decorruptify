        </lrml:PenaltyStatement>
        <lrml:PenaltyStatement key="pen_423b_max">
            <lrml:SuborderList>
                <lrml:Obligation>
                    <ruleml:Atom>
                        <ruleml:Rel iri=":max_imprisonment"/>
