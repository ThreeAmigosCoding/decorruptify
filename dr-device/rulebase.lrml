                </ruleml:if>
                <ruleml:then>
                    <ruleml:Negation>
                        <ruleml:Atom>
                            <ruleml:Rel>art420_basic</ruleml:Rel>
                            <ruleml:Var type=":defendant">Defendant</ruleml:Var>
                        </ruleml:Atom>
                    </ruleml:Negation>
                </ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <!-- ============================================================ -->
        <!-- Article 422 - Trgovina uticajem (Trading in influence)       -->
        <!-- ============================================================ -->

        <!-- ps6: Art. 422 basic form (6mo-5yr) -->
        <lrml:PrescriptiveStatement key="ps6">
            <ruleml:Rule key=":rule6" closure="universal" strength="defeasible">
                <ruleml:if>
                    <ruleml:And>
                        <ruleml:Atom>
                            <ruleml:Rel iri="lc:crime_type"/>
                            <ruleml:Var type="lc:defendant">Defendant</ruleml:Var>
                            <ruleml:Data xsi:type="xs:string">art422</ruleml:Data>
                        </ruleml:Atom>
