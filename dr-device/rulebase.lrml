                            <ruleml:Var type=":defendant">Defendant</ruleml:Var>
                        </ruleml:Atom>
                    </ruleml:Negation>
                </ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <!-- ============================================================ -->
        <!-- Article 424 - Davanje mita (Giving bribes)                   -->
        <!-- ============================================================ -->

        <!-- ps10: Art. 424 basic form - bribe given (6mo-5yr) -->
        <!-- Note: voluntary disclosure / acquittal (Art. 424 §4) is handled in Java -->
        <!-- before the engine runs, not as a LRML rule, to avoid class definition  -->
        <!-- issues in DR-DEVICE when a derived class has no penalty reparations.    -->
        <lrml:PrescriptiveStatement key="ps10">
            <ruleml:Rule key=":rule10" closure="universal" strength="defeasible">
                <ruleml:if>
                    <ruleml:And>
                        <ruleml:Atom>
                            <ruleml:Rel iri="lc:bribery_involved"/>
                            <ruleml:Var type="lc:defendant">Defendant</ruleml:Var>
                            <ruleml:Data xsi:type="xs:string">true</ruleml:Data>
                        </ruleml:Atom>
                        <ruleml:Atom>
                            <ruleml:Rel iri="lc:crime_type"/>
                            <ruleml:Var type="lc:defendant">Defendant</ruleml:Var>
                            <ruleml:Data xsi:type="xs:string">art424</ruleml:Data>
                        </ruleml:Atom>
                    </ruleml:And>
                </ruleml:if>
                <ruleml:then>
                    <ruleml:Atom>
                        <ruleml:Rel>art424_basic</ruleml:Rel>
                        <ruleml:Var type=":defendant">Defendant</ruleml:Var>
                    </ruleml:Atom>
                </ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <!-- ============================================================ -->
        <!-- Penalty Statements                                           -->
        <!-- ============================================================ -->

        <!-- Art. 416 basic: 1-5 years -->
        <lrml:PenaltyStatement key="pen_416b_min">
            <lrml:SuborderList>
                <lrml:Obligation>
                    <ruleml:Atom>
                        <ruleml:Rel iri=":min_imprisonment"/>
                        <ruleml:Var>Years</ruleml:Var>
                        <ruleml:Ind>1</ruleml:Ind>
                    </ruleml:Atom>
                </lrml:Obligation>
            </lrml:SuborderList>
        </lrml:PenaltyStatement>
        <lrml:PenaltyStatement key="pen_416b_max">
            <lrml:SuborderList>
                <lrml:Obligation>
                    <ruleml:Atom>
                        <ruleml:Rel iri=":max_imprisonment"/>
                        <ruleml:Var>Years</ruleml:Var>
                        <ruleml:Ind>5</ruleml:Ind>
                    </ruleml:Atom>
                </lrml:Obligation>
            </lrml:SuborderList>
        </lrml:PenaltyStatement>

        <!-- Art. 416 qualified gain: 1-10 years -->
        <lrml:PenaltyStatement key="pen_416qg_min">
            <lrml:SuborderList>
                <lrml:Obligation>
                    <ruleml:Atom>
                        <ruleml:Rel iri=":min_imprisonment"/>
                        <ruleml:Var>Years</ruleml:Var>
                        <ruleml:Ind>1</ruleml:Ind>
