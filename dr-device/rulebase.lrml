                <ruleml:then>
                    <ruleml:Atom>
                        <ruleml:Rel>art423_qualified</ruleml:Rel>
                        <ruleml:Var type=":defendant">Defendant</ruleml:Var>
                    </ruleml:Atom>
                </ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <!-- ps9_neg: qualified bribery defeats basic -->
        <lrml:PrescriptiveStatement key="ps9_neg">
            <ruleml:Rule key=":rule9_neg" closure="universal" strength="defeasible">
                <ruleml:if>
