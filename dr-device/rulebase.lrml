                        <ruleml:Atom>
                            <ruleml:Rel iri="lc:crime_type"/>
                            <ruleml:Var type="lc:defendant">Defendant</ruleml:Var>
                            <ruleml:Data xsi:type="xs:string">art420</ruleml:Data>
                        </ruleml:Atom>
                    </ruleml:And>
