        <!-- Art. 423 basic: 1-8 years -->
        <lrml:PenaltyStatement key="pen_423b_min">
            <lrml:SuborderList>
                <lrml:Obligation>
                    <ruleml:Atom>
                        <ruleml:Rel iri=":min_imprisonment"/>
                        <ruleml:Var>Years</ruleml:Var>
                        <ruleml:Ind>1</ruleml:Ind>
                    </ruleml:Atom>
                </lrml:Obligation>
