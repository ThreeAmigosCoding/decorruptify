                <lrml:Obligation>
                    <ruleml:Atom>
                        <ruleml:Rel iri=":min_imprisonment"/>
                        <ruleml:Var>Years</ruleml:Var>
                        <ruleml:Ind>1</ruleml:Ind>
                    </ruleml:Atom>
                </lrml:Obligation>
            </lrml:SuborderList>
        </lrml:PenaltyStatement>
        <lrml:PenaltyStatement key="pen_422b_max">
            <lrml:SuborderList>
