                    </ruleml:Atom>
                </ruleml:then>
            </ruleml:Rule>
        </lrml:PrescriptiveStatement>

        <!-- ps7: Art. 422 organized group (1-8yr) -->
        <lrml:PrescriptiveStatement key="ps7">
